{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "webviews": [
    "tabbar",
    "whatsnew",
    "tab-*"
  ],
  "remote": {
    "urls": [
      "https://*.notion.so",
      "https://notion.so",
      "https://*.notion.site"
    ]
  },
  "permissions": [
    "core:default",
    "dialog:default",
    "opener:default"
  ]
}
